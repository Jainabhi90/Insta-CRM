        "specifyBody": "json",
        "jsonBody": "={{ { instagramAccountId: $json.instagramAccountId, postId: $json.postId, comment: $json.comment, commenterId: $json.commenterId, commenterUsername: $json.commenterUsername, igUserId: $json.igUserId, commentId: $json.commentId, eventField: $json.eventField, followConfirmBaseUrl: $json.followConfirmBaseUrl } }}"
      },
      "id": "forward-comment-event",
      "name": "Forward Event To Backend",
