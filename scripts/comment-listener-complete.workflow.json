        720,
        320
      ]
    },
    {
      "parameters": {
        "jsCode": "const query = $input.first().json.query || {};\nreturn [{ json: { challenge: query['hub.challenge'] || '' } }];"
      },
      "id": "extract-challenge",
      "name": "Extract Challenge",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        960,
        320
      ]
    },
    {
      "parameters": {
        "respondWith": "text",
        "responseBody": "={{ $json.challenge }}"
      },
      "id": "respond-meta",
      "name": "Respond to Meta",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1.5,
      "position": [
        1200,
        320
      ]
    },
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "comment-listener-meta",
        "responseMode": "responseNode",
        "options": {}
      },
      "id": "meta-post-webhook",
      "name": "Receive Instagram Event (POST)",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2.1,
      "position": [
        720,
        640
      ]
    },
    {
      "parameters": {
        "jsCode": "const trigger = $input.first().json;\nconst body = trigger.body || {};\nconst headers = trigger.headers || {};\nconst proto = headers['x-forwarded-proto'] || headers['X-Forwarded-Proto'] || 'https';\nconst host = headers['x-forwarded-host'] || headers['X-Forwarded-Host'] || headers.host || '';\nlet n8nBaseUrl = '';\n\nif (host) {\n  n8nBaseUrl = `${proto}://${host}`;\n} else if (trigger.webhookUrl) {\n  try {\n    const url = new URL(trigger.webhookUrl);\n    n8nBaseUrl = `${url.protocol}//${url.host}`;\n  } catch (_error) {\n    n8nBaseUrl = '';\n  }\n}\n\nconst backendBaseUrl = 'http://127.0.0.1:4000';\nconst n8nSecret = 'replace-me-with-your-backend-secret';\nconst output = [];\n\nfor (const entry of body.entry || []) {\n  for (const change of entry.changes || []) {\n    if (change.field !== 'comments') continue;\n    const value = change.value || {};\n    output.push({\n      json: {\n        instagramAccountId: entry.id || '',\n        postId: value.media ? value.media.id : value.media_id || '',\n        comment: value.text ? value.text.trim() : '',\n        commenterId: value.from ? value.from.id : '',\n        commenterUsername: value.from ? value.from.username : '',\n        igUserId: value.from ? value.from.id : '',\n        commentId: value.id || '',\n        eventField: change.field || 'comments',\n        followConfirmBaseUrl: n8nBaseUrl ? `${n8nBaseUrl}/webhook/follow-confirm` : '',\n        backendBaseUrl,\n        n8nSecret\n      }\n    });\n  }\n}\n\nreturn output.length > 0 ? output : [{ json: { skip: true, backendBaseUrl, n8nSecret } }];"
      },
      "id": "parse-event",
      "name": "Parse Instagram Event",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1008,
        640
      ]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict",
            "version": 3
          },
          "conditions": [
            {
              "id": "ignore-empty-payload",
              "leftValue": "={{ $json.skip === true }}",
